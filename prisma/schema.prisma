generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     Int           @id @default(autoincrement())
  username               String
  email                  String        @unique
  password               String
  xp                     Int           @default(0)
  createdAt              DateTime      @default(now())
  role                   Role          @default(USER)
  level                  Level         @default(A0)
  updatedAt              DateTime?     @updatedAt
  streakCount            Int           @default(0)
  streakLastDay          String?
  emailConfirmationToken String?
  emailConfirmed         Boolean       @default(false)
  resetPasswordExpiry    DateTime?
  resetPasswordToken     String?
  nickname               String?       @unique
  chatMessages           ChatMessage[]
  following              Follow[]      @relation("UserFollowing")
  followers              Follow[]      @relation("UserFollowers")
  progress               Progress[]
  attempts               TaskAttempt[]
  dictionaryEntries      UserDictionaryEntry[]
  lectureProgress        UserLectureProgress[]
  xpHistory              UserXpHistory[]
  onboardingAnswers      UserOnboardingAnswer?
}

model Lesson {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  lectureText String?   @db.Text
  orderIndex  Int        @default(0)
  isArchived  Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  level       Level      @default(A0)
  progress    Progress[]
  lectureProgress UserLectureProgress[]
  tasks       Task[]
}

model Task {
  id            Int           @id @default(autoincrement())
  lessonId      Int
  type          TaskType      @default(SENTENCE_BUILD)
  promptLang    Lang
  targetLang    Lang
  promptText    String?
  optionsWords  Json?
  correctWords  Json?
  xpReward      Int           @default(10)
  orderIndex    Int           @default(0)
  isArchived    Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  audioText     String?
  audioUrl      String?
  translateText String?
  lesson        Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts      TaskAttempt[]
}

model Progress {
  id        Int            @id @default(autoincrement())
  userId    Int
  lessonId  Int
  status    ProgressStatus @default(NOT_STARTED)
  score     Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model TaskAttempt {
  id          Int      @id @default(autoincrement())
  userId      Int
  taskId      Int
  answerWords Json
  isCorrect   Boolean
  earnedXp    Int      @default(0)
  createdAt   DateTime @default(now())
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  xpHistory   UserXpHistory[]

  @@unique([userId, taskId])
}

model UploadedAudio {
  id        Int      @id @default(autoincrement())
  title     String
  audioUrl  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Book {
  id        Int      @id @default(autoincrement())
  title     String   @unique
  format    String
  pageCount Int
  author    String
  fileUrl   String   @db.Text
  fileKey   String   @unique
  mimeType  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
  @@index([author])
}

model UserDictionaryEntry {
  id            Int      @id @default(autoincrement())
  userId        Int
  word          String
  translationEn String?
  translationRu String?
  description   String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, word])
  @@index([userId, createdAt])
}

model UserOnboardingAnswer {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  goal               String
  studyMinutesDaily  Int
  currentLevel       String
  learningStyle      String
  focusArea          String
  preferredPace      String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserXpHistory {
  id            Int          @id @default(autoincrement())
  userId        Int
  amount        Int
  source        String?
  taskAttemptId Int?         @unique
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskAttempt   TaskAttempt? @relation(fields: [taskAttemptId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([createdAt])
}

model UserLectureProgress {
  id        Int      @id @default(autoincrement())
  userId    Int
  lessonId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson     Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, createdAt])
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  message   String   @db.VarChar(2000)
  role      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model AlphabetLetter {
  id              Int      @id @default(autoincrement())
  orderIndex      Int      @default(0)
  uppercase       String
  lowercase       String
  pronunciationRu String?
  pronunciationEn String?
  descriptionRu   String?
  descriptionEn   String?
  examples        Json?
  audioUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([uppercase, lowercase])
  @@index([orderIndex])
}

model KazakhLetter {
  id              Int     @id @default(autoincrement())
  letter          String  @db.Char(1)
  transcriptionRU String
  transcriptionEN String
  exampleWord     String?
  exampleWordRU   String?
  exampleWordEN   String?
  audioUrl        String?
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum Level {
  A0
  A1
  A2
  B1
  B2
  C1
  C2
}

enum TaskType {
  SENTENCE_BUILD
  AUDIO_DICTATION
  AUDIO_TRANSLATE
}

enum Lang {
  KZ
  RU
  EN
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ChatRole {
  USER
  AI
}
